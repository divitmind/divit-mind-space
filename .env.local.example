# Copy this file to .env.local for local development
# cp .env.local.example .env.local

# Sanity CMS Configuration
# For local dev without Sanity, use these placeholder values:
NEXT_PUBLIC_SANITY_PROJECT_ID=placeholder
NEXT_PUBLIC_SANITY_DATASET=production

# For actual Sanity integration, get your values from:
# https://sanity.io/manage → Your Project → API → Project ID

# Sanity Webhook Revalidation Secret
# Generate a random string and add it to both:
# 1. Vercel Environment Variables
# 2. Sanity Webhook configuration (as secret)
SANITY_REVALIDATE_SECRET=your-secret-token-here

# Google Analytics 4 — Measurement ID (format: G-XXXXXXXXXX)
# Get it from: https://analytics.google.com → Admin → Data Streams → Web → Measurement ID
# Leave blank or omit to disable GA tracking.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# IndexNow — pings Bing/ChatGPT/Perplexity when content changes so new pages
# index in minutes instead of days. The default key in lib/indexnow.ts is fine;
# override here if you rotate it. The corresponding <key>.txt file must exist
# at public/<key>.txt for Bing to verify ownership.
# INDEXNOW_KEY=0512d7470ecd49be85b4cd789ac7f948

# Set FORCE_INDEXNOW=1 to test pings from non-production environments. Otherwise
# IndexNow is auto-skipped outside production (avoids polluting Bing's index).
# FORCE_INDEXNOW=1
